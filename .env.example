# Claude API
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/consulting_sim
REDIS_URL=redis://localhost:6379/0
CHROMA_PERSIST_DIR=./data/chroma

# AWS credentials (used by Bedrock Converse adapter in backend/claude_client.py)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-west-1

# Auth
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Session limits
SESSION_MAX_TURNS=12
SESSION_TIMEOUT_SECONDS=240
SESSION_TOKEN_BUDGET=150000

# Model IDs (update if Anthropic renames)
MODEL_OPUS=claude-opus-4-5
MODEL_SONNET=claude-sonnet-4-5
MODEL_HAIKU=claude-haiku-4-5-20251001

# Observability
LOGFIRE_TOKEN=
ENVIRONMENT=development

# Memory encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MEMORY_ENCRYPTION_KEY=
